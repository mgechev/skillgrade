{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen3-4b-skill-eval-opencode-agent": {
          "name": "Qwen3 4B OpenCode Agent",
          "tools": true
        }
      }
    }
  },
  "model": "ollama/qwen3-4b-opencode-agent",
  "permission": {
    "read": "allow",
    "edit": "allow",
    "bash": "allow",
    "write": "allow",
    "glob": "deny",
    "grep": "deny",
    "list": "deny",
    "task": "deny",
    "todowrite": "deny",
    "skill": "deny",
    "webfetch": "deny",
    "websearch": "deny",
    "codesearch": "deny",
    "external_directory": "deny",
    "doom_loop": "allow"
  }
}
