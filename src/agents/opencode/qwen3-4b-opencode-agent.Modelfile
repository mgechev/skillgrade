# Modelfile for the opencode agent variant of qwen3:4b.
#
# Qwen3 uses the stable Hermes-style tool calling format on Ollama.
# Qwen 3.5 has broken tool calling on Ollama (issues #14493, #14745).
# NO custom SYSTEM prompt -- opencode provides its own.
#
# To create: ollama create qwen3-4b-opencode-agent -f qwen3-4b-opencode-agent.Modelfile

FROM qwen3:4b
PARAMETER num_ctx 8192
PARAMETER num_predict 4096
PARAMETER temperature 0
PARAMETER num_batch 1024
PARAMETER num_thread 8
