# Modelfile for the opencode agent variant of qwen2.5:3b.
#
# Same base model and performance parameters as qwen2.5-3b-skill-eval-agent,
# but WITHOUT a custom SYSTEM prompt. Opencode provides its own system prompt
# and tool definitions via the OpenAI-compatible API (/v1), so the Modelfile
# must not override them.
#
# To create: ollama create qwen2.5-3b-opencode-agent -f qwen2.5-3b-opencode-agent.Modelfile

FROM qwen2.5:3b
PARAMETER num_predict 4096
PARAMETER num_thread 8
PARAMETER temperature 0
PARAMETER num_batch 1024
PARAMETER num_ctx 4096
